      <Parameter Name="Position [um]" Description="Current absolute camera z." Type="DBL" Direction="Output" ValueType="Variable" VariableName="d_CameraZUm" />
      <Parameter Name="Message" Description="Stage status." Type="String" Direction="Output" ValueType="Variable" VariableName="s_QueryStageMessage" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="QueryStage" Library="Stage">
      <Parameter Name="Stage" Description="Tower 1 X stage." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Align_X1" />
      <Parameter Name="Query" Description="Absolute machine coordinate." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Absolute" />
      <Parameter Name="Position [um]" Description="Current absolute tower 1 x." Type="DBL" Direction="Output" ValueType="Variable" VariableName="d_Tower1XUm" />
      <Parameter Name="Message" Description="Stage status." Type="String" Direction="Output" ValueType="Variable" VariableName="s_QueryStageMessage" />
