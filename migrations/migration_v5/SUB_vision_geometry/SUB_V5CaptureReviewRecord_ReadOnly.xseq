<?xml version="1.0" encoding="ISO-8859-1"?>
<Sequence>
   <Comment>SUB_V5CaptureReviewRecord_ReadOnly</Comment>
   <Comment>Read-only live v5 capture bridge. Grabs CAM_12, saves the frame, queries current machine positions, then opens the Python review UI before recording memory.</Comment>
   <Comment>No hardware motion is used. Python fails closed unless the operator selects the reviewed circle/rectangle features in the UI.</Comment>
   <Statement Label="L_Start" Editable="FALSE" Name="****" Library="XSEQFlowControl">
      <Parameter Name="Comment" Description="Enter comment text." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="DisplayStatus" Library="Standard">
      <Parameter Name="Status text" Description="Checkout status." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="V5 capture review record: grabbing CAM_12 frame" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="StageCheckAllFiducialed" Library="Stage">
      <Parameter Name="Fiducialed?" Description="Result: Returns, if stage is fiducialized (true) or not (false)." Type="Boolean" Direction="Output" ValueType="Variable" VariableName="b_StagesFiducialed" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="ifnum" Library="Standard">
      <Parameter Name="Num1" Description="Fiducial state." Type="DBL" Direction="Input" ValueType="Variable" VariableName="b_StagesFiducialed" />
      <Parameter Name="Comp" Description="Comparison." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="=" />
      <Parameter Name="Num2" Description="False." Type="DBL" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="0.0" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="Goto" Library="XSEQFlowControl">
      <Parameter Name="Label" Description="Abort if stages are not fiducialed." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="L_Error_Fiducial" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="Grab" Library="AdvancedIMAQ">
      <Parameter Name="Camera" Description="Camera used for v5 vision review." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="CAM_12" />
      <Parameter Name="Image Out" Description="Flattened reference to the acquired image." Type="String" Direction="Output" ValueType="Variable" VariableName="r_Image_Ref" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="IMAQWriteFile" Library="AdvancedIMAQ">
      <Parameter Name="Image In" Description="The exact image reference returned by Grab." Type="String" Direction="Input" ValueType="Variable" VariableName="r_Image_Ref" />
      <Parameter Name="FileName" Description="Filename relative to the Python_Automation process data directory." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="python_vision_input.bmp" />
      <Parameter Name="FileType" Description="Lossless uncompressed Windows bitmap." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="BMP" />
   </Statement>
   <Statement Label="L_QueryCameraX" Editable="FALSE" Name="QueryStage" Library="Stage">
      <Parameter Name="Stage" Description="Camera X stage." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Camera_X" />
      <Parameter Name="Query" Description="Absolute machine coordinate." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Absolute" />
      <Parameter Name="Position [um]" Description="Current absolute camera x." Type="DBL" Direction="Output" ValueType="Variable" VariableName="d_CameraXUm" />
      <Parameter Name="Message" Description="Stage status." Type="String" Direction="Output" ValueType="Variable" VariableName="s_QueryStageMessage" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="QueryStage" Library="Stage">
      <Parameter Name="Stage" Description="Camera Y stage." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Camera_Y" />
      <Parameter Name="Query" Description="Absolute machine coordinate." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Absolute" />
      <Parameter Name="Position [um]" Description="Current absolute camera y." Type="DBL" Direction="Output" ValueType="Variable" VariableName="d_CameraYUm" />
      <Parameter Name="Message" Description="Stage status." Type="String" Direction="Output" ValueType="Variable" VariableName="s_QueryStageMessage" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="QueryStage" Library="Stage">
