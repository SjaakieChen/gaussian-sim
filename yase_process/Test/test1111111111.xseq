   <Statement Label="" Editable="FALSE" Name="MetrologyShowLineScanFitFromFile" Library="product_modules\Functions\OpticalMetrology\Metrology">
      <Parameter Name="File" Description="Path to the LineScan data file. (TM_Path definition is allowed)" Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="D:\TestMasterData\data\FA_Align\202311281329_000" />
      <Parameter Name="Method" Description="Method that should be used to fit the data." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Gauss" />
      <Parameter Name="Polynomial order" Description="Polynominal order of the polynominal function that should be used for the fit." Type="I32" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="ResultSelect" Description="Select which result should be returned (Minimal or Maximal value)." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Max" />
      <Parameter Name="ShowScan?" Description="Select whether to show a LineScan panel with the fitted data." Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="true" />
