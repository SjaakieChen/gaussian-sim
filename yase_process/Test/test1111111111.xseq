   <Statement Label="" Editable="FALSE" Name="MetrologyLineScan" Library="product_modules\Functions\OpticalMetrology\Metrology">
      <Parameter Name="Setup" Description="Parameter: Activate parameters entered in the sequence by ****. If a Parameter Set is selected from the drop down list, the chosen parameters set is activated." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="****" />
      <Parameter Name="ShowScan?" Description="&quot;Parameter: Select, if the scan is shown as a graph in the display area of the Line Scan panel: True=Scan is displayed; False=Scan is not displayed.&quot;" Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="true" />
      <Parameter Name="Timeout(ms)" Description="Parameter:  Enter timeout for ShowScan? in ms." Type="U32" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="0.0" />
      <Parameter Name="%" Description="Parameter: % value of maximum at which to calculate the FWHM." Type="DBL" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="Meter" Description="Parameter: Select a meter from drop down list." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="TIA1" />
      <Parameter Name="Stage" Description="Parameter: Select a stage from drop down list." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Align_Yaw2" />
      <Parameter Name="Step width (µm)" Description="Parameter: Define step width in µm." Type="DBL" Direction="Input" ValueType="Constant" NumericValue="5.0" StringValue="5.0" />
      <Parameter Name="Scan range (µm)" Description="Parameter: Define scan length in µm." Type="DBL" Direction="Input" ValueType="Constant" NumericValue="300.0" StringValue="300.0" />
      <Parameter Name="Speed" Description="Parameter:  Define speed in µm/s.(Nan=Automatic:Positioning speed and Return speed - Scan_range x1000; Measurement speed- Scan_range x100) " Type="DBL" Direction="Input" ValueType="Constant" NumericValue="25.0" StringValue="25.0" />
      <Parameter Name="Return to" Description="Parameter: Return to starting position, min or max." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Max" />
      <Parameter Name="Initial move?" Description="&quot;Parameter: Switch initial move on or off: true = on; false = off.&quot;" Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="true" />
      <Parameter Name="ScanDirection" Description="" Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="true" />
      <Parameter Name="GaussFit" Description="Parameter: Enter order of polynomial fit." Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="Polynomial order" Description="" Type="I32" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="Save?" Description="&quot;Parameter: Decide to save the resulting; True=save on; False= save off.&quot;" Type="Boolean" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="FileName" Description="Parameter: Result is saved in the data folder of the current process with the given name." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="FWHM" Description="Result: Width of scanned curve of Meter at given % of maximum." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="Max Pos" Description="Result: Returns position of maximum, minimum, start intensity on Stage, depending on the Return to position." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="Max Int" Description="Result: Returns maximum, minimum, start intensity." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="mse" Description="" Type="DBL" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
      <Parameter Name="aborted" Description="" Type="Boolean" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
   </Statement>
