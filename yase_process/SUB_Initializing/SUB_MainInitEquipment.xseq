      <Parameter Name="Function" Description="Parameter: Switch between get and set: Get: actual mode of FEMTO hardware driver is used. Set: set FEMTO mode." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Set" />
      <Parameter Name="OffsetIn" Description="Parameter: Set offset value in a range between+-10V." Type="DBL" Direction="Input" ValueType="Variable" VariableName="TIA1Offset" />
      <Parameter Name="OffsetOut" Description="Result: Returns offset value." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="TIARange" Library="product_modules\Devices\Sources_Meter\TIA\TIA">
      <Parameter Name="Meter" Description="Parameter: Select a power meter from drop down list." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="TIA1" />
      <Parameter Name="Function" Description="Parameter: Switch between get and set: Get: actual mode of FEMTO hardware driver is used. Set: set FEMTO mode." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Set" />
      <Parameter Name="GainIn" Description="Parameter: Enter range between 0 and 6; 0 is least sensitive, 6 most sensitive ranges." Type="DBL" Direction="Input" ValueType="Variable" VariableName="TIA1Range" />
      <Parameter Name="GainOut" Description="Result: Returns range value." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="5.0" StringValue="5.0" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="TIAWavelength" Library="product_modules\Devices\Sources_Meter\TIA\TIA">
      <Parameter Name="Meter" Description="Parameter: Select a power meter from drop down list." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="TIA1" />
      <Parameter Name="Function" Description="Parameter: Switch between get and set: Get: actual mode of FEMTO hardware driver is used. Set: set FEMTO mode." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Set" />
      <Parameter Name="WavelengthIn" Description="Parameter: Enter wavelength." Type="DBL" Direction="Input" ValueType="Variable" VariableName="TIA1Wavelength" />
      <Parameter Name="WavelengthOut" Description="Parameter: Returns wave length." Type="DBL" Direction="Output" ValueType="Constant" NumericValue="1500.0" StringValue="1500.0" />
   </Statement>
   <Statement Label="" Editable="FALSE" Name="TIAPolarity" Library="product_modules\Devices\Sources_Meter\TIA\TIA">
      <Parameter Name="Meter" Description="Parameter: Select a power meter from drop down list." Type="String" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="TIA1" />
      <Parameter Name="Function" Description="Parameter: Select a power meter from drop down list." Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="Set" />
      <Parameter Name="ModeIn" Description="Parameter: Switch between High Speed and Low Noise Mode." Type="Enum Word" Direction="Input" ValueType="Variable" VariableName="TIA1Polarity" />
      <Parameter Name="ModeOut" Description="Parameter: Returns Femto mode." Type="U16" Direction="Output" ValueType="Constant" NumericValue="0.0" StringValue="" />
   </Statement>
