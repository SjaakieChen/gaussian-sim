      <Parameter Name="Operation" Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="+" />
      <Parameter Name="Number 2 in" Type="DBL" Direction="Input" ValueType="Variable" VariableName="d_Delta1" />
      <Parameter Name="Number out" Type="DBL" Direction="Output" ValueType="Variable" VariableName="d_Target1" />
