   <Statement Label="" Editable="FALSE" Name="calc" Library="Standard">
      <Parameter Name="Number 1 in" Type="DBL" Direction="Input" ValueType="Variable" VariableName="d_Offset" />
      <Parameter Name="Operation" Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="*" />
      <Parameter Name="Number 2 in" Type="DBL" Direction="Input" ValueType="Variable" VariableName="d_Sign2" />
