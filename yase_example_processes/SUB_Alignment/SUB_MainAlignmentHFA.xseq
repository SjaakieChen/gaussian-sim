      <Parameter Name="Threshold optional" Description="Threshold value for SpiralRough operation only. If a Threshold value &lt;&gt; 0 is entered this value overwrittes the one given in the selected parameter set." Type="DBL" Direction="Input" ValueType="Constant" NumericValue="10.0" StringValue="10.0" />
      <Parameter Name="Display" Description="" Type="Enum Word" Direction="Input" ValueType="Constant" NumericValue="0.0" StringValue="show" />
